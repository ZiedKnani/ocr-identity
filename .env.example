# OCR Identity v2 - Configuration d'exemple
# Copier ce fichier en .env et adapter les valeurs

# === Application ===
LOG_LEVEL=INFO                      # DEBUG, INFO, WARNING, ERROR
MAX_WORKERS=4                       # Nombre de workers pour traitement parallèle
OCR_LANGUAGE=fr                     # Langue OCR (fr, en, zh, es, etc.)
PYTHONUNBUFFERED=1                  # Force unbuffered stdout (important en Docker)

# === API ===
API_HOST=0.0.0.0                    # Host d'écoute (0.0.0.0 pour Docker)
API_PORT=8000                       # Port d'écoute
API_WORKERS=4                       # Nombre de workers Uvicorn

# === Optional: SMB Network Access (si fichiers sur serveur réseau) ===
# SMB_USERNAME=your_user
# SMB_PASSWORD=your_password
# SMB_DOMAIN=your_domain
# SMB_PATH=\\192.168.1.100\shared\path

# === Optional: Database Connection ===
# DATABASE_URL=postgresql://user:password@localhost:5432/ocr_db
# REDIS_URL=redis://localhost:6379/0

# === Security (production only) ===
# SECRET_KEY=your-secret-key-min-32-characters-long
# DEBUG=False
